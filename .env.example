# Domain Configuration
DOMAIN=example.com
ENABLE_HTTPS=false

# Frontend Exposure Ports (Nginx)
FRONTEND_HTTP_PORT=80
FRONTEND_HTTPS_PORT=443

# Internal Service Ports (Usually no need to change)
BACKEND_PORT=5050
MONGO_PORT=27017

# Database
MONGO_DB=blog

# Frontend API Configuration
# Client-side API Base URL.
# If empty, requests use relative path (e.g. /api/...) which works with Nginx.
# If set to absolute URL (e.g. https://api.example.com), client requests go there.
# WARNING: Do NOT set to http://backend:5050 as client browser cannot reach docker service name.
NEXT_PUBLIC_API_BASE_URL=

# Backend Secrets (Required)
ACCESS_SECRET=your_access_secret_key
REFRESH_SECRET=your_refresh_secret_key
OWNER_SECRET=your_owner_secret_key

# Mail Configuration (Required)
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USER=user@example.com
MAIL_PASS=password
